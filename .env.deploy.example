# Deployment env file for docker compose
# Copy to .env.deploy on server and fill real values.

ENVIRONMENT=production
RUN_AUTO_MIGRATE=false

# Database
DB_PASSWORD=change_me_very_strong_password

# Security
SECRET_KEY=change_this_to_64_character_random_string
CORS_ORIGINS=http://你的服务器IP,https://yourdomain.com
MAX_REQUESTS_PER_MINUTE=100
ADMIN_USERNAMES=your_admin_username
LOG_LEVEL=INFO

# AI
ANTHROPIC_AUTH_TOKEN=sk-your_api_key_here
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=deepseek-v4-pro
