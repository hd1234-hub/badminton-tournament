# ==========================================
# 生产环境配置文件示例
# 复制为 .env 后修改实际值
# ==========================================

# ==================== 运行模式 ====================
ENVIRONMENT=production
RUN_AUTO_MIGRATE=false

# ==================== 数据库配置（生产必改）====================
# PostgreSQL连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://badminton:your_secure_password@localhost:5432/badminton

# ==================== 安全配置（生产必改）====================
# JWT密钥 - 必须设置强随机字符串！
# 生成方式: openssl rand -hex 32
SECRET_KEY=change_this_to_64_character_random_string_in_production

# CORS允许的域名（逗号分隔）
# 生产环境改为实际前端域名
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# API限流 - 每分钟最大请求数
MAX_REQUESTS_PER_MINUTE=60
ADMIN_USERNAMES=

# ==================== AI配置 ====================
# Anthropic API密钥
ANTHROPIC_AUTH_TOKEN=sk-your_production_api_key_here

# API代理地址（可选）
ANTHROPIC_BASE_URL=

# 使用的模型
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 可选：Redis配置 ====================
# 用于分布式限流和缓存
# REDIS_URL=redis://localhost:6379/0
