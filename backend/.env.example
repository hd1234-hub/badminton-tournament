# ==================== Runtime ====================
ENVIRONMENT=development
RUN_AUTO_MIGRATE=true
LOG_LEVEL=INFO

# ==================== Database ====================
# Local example (PostgreSQL)
DATABASE_URL=postgresql://badminton:change_me@localhost:5432/badminton

# ==================== Security ====================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_this_to_a_secure_random_value
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
MAX_REQUESTS_PER_MINUTE=60
ADMIN_USERNAMES=

# ==================== AI ====================
# Keep empty in open-source repo. Fill locally on your machine/server.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=deepseek-v4-pro
